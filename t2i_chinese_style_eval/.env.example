# ─────────────────────────────────────────────
# T2I 中国传统视觉风格评测 —— 环境变量模板
# ─────────────────────────────────────────────
# 用法：
#   1. 复制本文件为 .env：  cp .env.example .env
#   2. 把下面占位 sk-xxx... 替换成你自己的真实 key
#   3. .env 已被 .gitignore 排除，不会提交到 git
# ─────────────────────────────────────────────

# 阿里云 DashScope (Qwen Image 2.0 Pro / Qwen-VL)
# 获取地址：https://bailian.console.aliyun.com/?apiKey=1
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI (GPT Image 2 生成 / GPT-4o 客观评价)
# 获取地址：https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini (正式版交叉验证用，MVP 可留空)
# 获取地址：https://aistudio.google.com/apikey
GEMINI_API_KEY=

# 火山引擎 / 即梦同源文生图 3.1 (M03)
# 访问密钥获取地址：https://console.volcengine.com/iam/keymanage/
# 文生图服务控制台：https://console.volcengine.com/visual/
# Region 固定 cn-north-1，Service 固定 cv
VOLC_ACCESS_KEY_ID=AKxxxxxxxxxxxxxxxx
VOLC_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
